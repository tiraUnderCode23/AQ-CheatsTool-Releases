        {
          "title": "Navigate to job",
          "text": "steuern_ews4_sk",
          "image": "https://raw.githubusercontent.com/tiraUnderCode23/AQ-CheatsTool-Releases/main/uploads/images/1776430567967_IMG-20260408-WA0024.jpg"
        },
        {
          "title": "Unlock DME using old ISN",
          "text": "UNLOCK_CLIENT_SK (used ISN)",
          "image": "https://raw.githubusercontent.com/tiraUnderCode23/AQ-CheatsTool-Releases/main/uploads/images/1776430657168_Screenshot_20260417_155716_Gallery.jpg"
        },
        {
          "title": "Write new ISN:",
          "text": "WRITE_CLIENT_SK (new ISN)\n- WRITE_SERVER_SK (new ISN)"
        },
        {
          "title": "Lock the system",
          "text": "LOCK_CLIENT_SK (new ISN)\n- LOCK_SERVER_SK (new ISN)"
        },
        {
          "title": "ISN Status Check (EWS5)",
          "text": "+ Job: STATUS_LESEN → ARG;EWS_DME_LESEN\n+ 01 = ISN not reset\n+ 00 = ISN synchronized successfully"
        },
        {
          "title": "✅ Additional Notes:",
          "text": "Flash & encode DME first using E-Sys\n- Disable FSC → reset VIN to 00000000000000000\n- Extract ISN from dump (hex → decimal)\n- Use MG1 WRK.TST for calculation & ISN injection"
        },
        {
          "title": "⚠️ Technical Notes",
          "text": "Identify correct Master (12) / Slave (13) when injecting ISN\n- Incorrect ISN → no start or sync errors\n- Always keep original ISN as backup"
        }
      ]
